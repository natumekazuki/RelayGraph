{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relaygraph.local/schema/sidecar.schema.json",
  "title": "RelayGraph Sidecar",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "metadata": {
      "type": "object"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rel", "to"],
        "properties": {
          "rel": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "to": {
            "type": "string",
            "pattern": "^(id:.*\\S.*|path:(?!.?:)(?![\\\\/])(?!.*[\\\\/]\\.\\.([\\\\/]|$))(?!\\.\\.([\\\\/]|$)).*\\S.*)$"
          },
          "pathHint": {
            "type": "string",
            "pattern": "^(?!.?:)(?![\\\\/])(?!.*[\\\\/]\\.\\.([\\\\/]|$))(?!\\.\\.([\\\\/]|$)).*\\S.*$"
          },
          "order": {
            "type": "integer"
          }
        }
      },
      "default": []
    }
  }
}
