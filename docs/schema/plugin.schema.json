{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relaygraph.local/schema/plugin.schema.json",
  "title": "RelayGraph YAML Plugin",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "resourceKinds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      },
      "uniqueItems": true,
      "default": []
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      },
      "uniqueItems": true,
      "default": []
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["when"],
        "properties": {
          "when": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "requireAnyOutgoing": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "default": []
          },
          "requireReachableKinds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "default": []
          }
        }
      },
      "default": []
    },
    "traversal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "default": []
        },
        "relationOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "default": []
        }
      }
    }
  }
}
