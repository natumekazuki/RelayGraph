<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="RelayGraph"
    Manufacturer="natumekazuki"
    Version="$(var.ProductVersion)"
    UpgradeCode="8C5A56C9-1F2D-4C2E-B9B2-06F75C59E5D0"
    Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of RelayGraph is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="RelayGraph">
        <Component Id="RelayGraphExecutable" Guid="F30C9275-4576-4783-812F-828865E13491">
          <File Id="RelayGraphExe" Source="$(var.RelayGraphExe)" KeyPath="yes" />
          <Environment
            Id="RelayGraphPath"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="RelayGraph" Level="1">
      <ComponentRef Id="RelayGraphExecutable" />
    </Feature>
  </Package>
</Wix>
